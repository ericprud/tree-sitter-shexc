{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "shexc",
      "camelcase": "ShExC",
      "title": "Shape Expressions Compact Syntax parser",
      "scope": "source.shexc",
      "file-types": [
        "shex"
      ],
      "injection-regex": "^shexc$",
      "class-name": "TreeSitterShexc"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "parser for Shape Expressions Compact Syntax",
    "authors": [
      {
        "name": "ericP",
        "email": "eric+github@uu3.org",
        "url": "https://github.com/ericprud"
      }
    ],
    "links": {
      "repository": "https://github.com/ericprud/tree-sitter-shexc",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}